{
  "_comment": "Gemini CLI translator preset — 走 gemini -p headless CLI，使用 Google AI 訂閱 OAuth / AI Studio free tier，無 API key 計費。",
  "filter_text_enabled": false,
  "kernel_size": 3,
  "mask_dilation_offset": 50,
  "use_custom_api_params": false,
  "translator": {
    "translator": "gemini_cli",
    "target_lang": "CHT",
    "keep_lang": "none",
    "enable_streaming": false,
    "no_text_lang_skip": false,
    "high_quality_prompt_path": "dict/manga_hq_zh.yaml",
    "extract_glossary": false,
    "max_requests_per_minute": 0,
    "remove_trailing_period": true,
    "enable_post_translation_check": true,
    "post_check_max_retry_attempts": 2,
    "post_check_target_lang_threshold": 0.5
  },
  "ocr": {
    "ocr": "paddleocr_vl",
    "use_hybrid_ocr": true,
    "secondary_ocr": "mocr",
    "min_text_length": 0,
    "ignore_bubble": 0.0,
    "use_model_bubble_filter": false,
    "model_bubble_overlap_threshold": 0.1,
    "use_model_bubble_repair_intersection": false,
    "limit_mask_dilation_to_bubble_mask": true,
    "prob": 0.1,
    "merge_gamma": 0.8,
    "merge_sigma": 2.5,
    "merge_edge_ratio_threshold": 0.0,
    "merge_special_require_full_wrap": true,
    "ocr_vl_language_hint": "Japanese",
    "ocr_vl_custom_prompt": null,
    "ai_ocr_concurrency": 1,
    "ai_ocr_custom_prompt": null
  },
  "detector": {
    "detector": "default",
    "detection_size": 2048,
    "text_threshold": 0.5,
    "box_threshold": 0.5,
    "unclip_ratio": 2.5,
    "import_yolo_labels": false,
    "use_yolo_obb": true,
    "yolo_obb_conf": 0.4,
    "yolo_obb_overlap_threshold": 0.1,
    "min_box_area_ratio": 0
  },
  "inpainter": {
    "inpainter": "lama_large",
    "inpainting_size": 2048,
    "inpainting_precision": "fp32",
    "force_use_torch_inpainting": false
  },
  "render": {
    "renderer": "default",
    "alignment": "auto",
    "disable_font_border": false,
    "disable_auto_wrap": false,
    "font_size_offset": 0,
    "font_size_minimum": 0,
    "direction": "auto",
    "uppercase": false,
    "lowercase": false,
    "font_path": "fonts/Arial-Unicode-Regular.ttf",
    "no_hyphenation": false,
    "font_color": null,
    "line_spacing": 1.0,
    "letter_spacing": 1.0,
    "font_size": null,
    "auto_rotate_symbols": true,
    "rtl": true,
    "layout_mode": "smart_scaling",
    "max_font_size": 0,
    "font_scale_ratio": 1.0,
    "center_text_in_bubble": false,
    "optimize_line_breaks": true,
    "check_br_and_retry": true,
    "strict_smart_scaling": true,
    "stroke_width": 0.07,
    "enable_template_alignment": false,
    "paste_mask_dilation_pixels": 10,
    "ai_renderer_concurrency": 1
  },
  "upscale": {
    "upscaler": "mangajanai",
    "upscale_ratio": null,
    "realcugan_model": null,
    "tile_size": 400,
    "revert_upscaling": false
  },
  "colorizer": {
    "colorization_size": 2048,
    "denoise_sigma": 30,
    "colorizer": "none",
    "ai_colorizer_history_pages": 0
  },
  "cli": {
    "verbose": true,
    "attempts": 3,
    "ignore_errors": false,
    "use_gpu": true,
    "disable_onnx_gpu": false,
    "context_size": 5,
    "format": null,
    "overwrite": false,
    "skip_no_text": false,
    "save_text": true,
    "load_text": false,
    "translate_json_only": false,
    "template": false,
    "save_quality": 100,
    "batch_size": 1,
    "batch_concurrent": false,
    "generate_and_export": false,
    "colorize_only": false,
    "upscale_only": false,
    "inpaint_only": false,
    "save_to_source_dir": false,
    "export_editable_psd": false,
    "psd_font": null,
    "psd_script_only": false,
    "replace_translation": false
  }
}